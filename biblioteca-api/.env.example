PORT=3000

# Allowed origins separated by comma. Example: http://localhost:8081,http://192.168.1.8:8081
ALLOWED_ORIGINS=*

# In production, set NODE_ENV=production to avoid exposing recovery codes.
NODE_ENV=development

# JWT — OBRIGATORIO em producao. Gere com: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=8h

# Optional SMTP setup (recommended for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Biblioteca Escolar <nao-responder@escola.local>"

# Anthropic — necessário para a assistente virtual Marlene
# Gere em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
